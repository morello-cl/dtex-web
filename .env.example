# API key de Resend (https://resend.com/api-keys).
# Necesaria para enviar correos desde el formulario /contacto.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# (Opcional) Destinatario de los mensajes del formulario.
# Default: ventas@dtex.cl (ver src/lib/site.ts).
# CONTACT_TO=ventas@dtex.cl

# (Opcional) Remitente — debe ser una dirección en un dominio verificado en Resend.
# Default: "DTEx® Web <no-reply@mail.dtex.cl>" (dominio verificado: mail.dtex.cl).
# CONTACT_FROM=DTEx® Web <no-reply@mail.dtex.cl>

# (Opcional, solo dev) Si MOCK_EMAIL=1, el formulario /comercios no llama a Resend:
# loguea el payload en consola y devuelve success. Útil para probar el flujo
# end-to-end sin gastar la API key.
# MOCK_EMAIL=1

# (Opcional) Destinatario específico de inscripciones de comercios.
# Default: usa CONTACT_TO, y si no, ventas@dtex.cl.
# COMERCIOS_TO=ops@dtex.cl
